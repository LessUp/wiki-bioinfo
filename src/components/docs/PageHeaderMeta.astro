---
interface Props {
  section: string;
  audience: string;
  startWith: string;
}

import { Icon } from '@astrojs/starlight/components';

const { section, audience, startWith } = Astro.props;
---

<div class="header-meta-grid">
  <div class="header-meta-card">
    <span class="meta-label"><Icon name="list-format" size="1rem" /> 所属板块</span>
    <strong>{section}</strong>
  </div>
  <div class="header-meta-card">
    <span class="meta-label"><Icon name="random" size="1rem" /> 适合谁读</span>
    <strong>{audience}</strong>
  </div>
  <div class="header-meta-card">
    <span class="meta-label"><Icon name="right-arrow" size="1rem" /> 建议起点</span>
    <strong>{startWith}</strong>
  </div>
</div>
