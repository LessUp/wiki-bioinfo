---
interface Props {
  title?: string;
  items?: string[];
  pitfalls?: string[];
}

import { Icon } from '@astrojs/starlight/components';

const { title = '常见误区', items = [], pitfalls = [] } = Astro.props;
const resolvedItems = items.length > 0 ? items : pitfalls;
---

<aside class="note-card pitfalls-card">
  <strong><Icon name="warning" size="1.2rem" /> {title}</strong>
  <ul>
    {resolvedItems.map((item) => <li>{item}</li>)}
  </ul>
</aside>
