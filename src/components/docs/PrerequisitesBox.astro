---
interface Props {
  title?: string;
  items?: Array<string | {
    name?: string;
    title?: string;
    label?: string;
    text?: string;
    href?: string;
    to?: string;
  }>;
}

import { Icon } from '@astrojs/starlight/components';
import { buildHref, isExternalHref } from './link-utils';

const { title = '前置知识', items = [] } = Astro.props;
const base = import.meta.env.BASE_URL;

const resolvedItems = items.map((item) => {
  if (typeof item === 'string') {
    return {
      label: item,
    };
  }

  const target = item.href ?? item.to;
  const href = target ? buildHref(target, base) : undefined;

  return {
    label: item.label ?? item.name ?? item.title ?? item.text ?? target ?? '',
    href,
    external: href ? isExternalHref(href) : false,
  };
});
---

<aside class="note-card">
  <strong><Icon name="open-book" size="1.2rem" /> {title}</strong>
  {resolvedItems.length > 0 && (
    <ul>
      {resolvedItems.map((item) => (
        <li>
          {item.href ? (
            <a
              href={item.href}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noopener noreferrer' : undefined}
            >
              {item.label}
            </a>
          ) : item.label}
        </li>
      ))}
    </ul>
  )}
  <slot />
</aside>
