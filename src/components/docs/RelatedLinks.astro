---
interface RelatedLink {
  title: string;
  to: string;
  description: string;
  label?: string;
}

interface Props {
  links: RelatedLink[];
}

const { links } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function resolveHref(to: string): string {
  if (to.startsWith('http')) return to;
  const cleaned = to.replace(/^\/docs\//, '/');
  return `${base}${cleaned}`;
}
---

<div class="related-grid">
  {links.map((link) => (
    <a class="related-card" href={resolveHref(link.to)}>
      {link.label && <span class="related-label">{link.label}</span>}
      <h3>{link.title}</h3>
      <p>{link.description}</p>
      <span class="secondary-action">延伸阅读</span>
    </a>
  ))}
</div>
