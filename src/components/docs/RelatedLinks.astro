---
interface RelatedLink {
  title: string;
  to: string;
  description: string;
  label?: string;
}

interface Props {
  links: RelatedLink[];
}

import { Icon } from '@astrojs/starlight/components';
import { buildHref, isExternalHref } from './link-utils';

const { links } = Astro.props;
const base = import.meta.env.BASE_URL;

const resolvedLinks = links.map((link) => {
  const href = buildHref(link.to, base);

  return {
    ...link,
    href,
    external: isExternalHref(href),
  };
});
---

<div class="related-grid">
  {resolvedLinks.map((link) => (
    <a
      class="related-card"
      href={link.href}
      target={link.external ? '_blank' : undefined}
      rel={link.external ? 'noopener noreferrer' : undefined}
    >
      <div class="related-header">
        {link.label && <span class="related-label">{link.label}</span>}
        {link.external && <Icon name="external" size="1rem" />}
      </div>
      <h3>{link.title}</h3>
      <p>{link.description}</p>
      <span class="secondary-action">
        延伸阅读
        <Icon name="right-arrow" size="0.9rem" />
      </span>
    </a>
  ))}
</div>
