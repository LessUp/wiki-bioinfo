---
interface Props {
  title?: string;
  summary?: string;
  bullets?: string[];
}

import { Icon } from '@astrojs/starlight/components';

const { title = '快速概览', summary, bullets = [] } = Astro.props;
---

<section class="summary-card">
  <strong><Icon name="rocket" size="1.2rem" /> {title}</strong>
  {summary && <p>{summary}</p>}
  <slot />
  {bullets.length > 0 && (
    <ul>
      {bullets.map((bullet) => <li>{bullet}</li>)}
    </ul>
  )}
</section>
