---
interface WorkflowStep {
  title: string;
  description: string;
  hint?: string;
  badge?: string;
}

interface Props {
  steps: WorkflowStep[];
}

const { steps } = Astro.props;
---

<div class="workflow-grid">
  {steps.map((step, index) => (
    <div class="workflow-card">
      <div class="step-index">{index + 1}</div>
      <div class="workflow-content">
        {step.badge && <span class="card-badge">{step.badge}</span>}
        <h3>{step.title}</h3>
        <div class="workflow-description">{step.description}</div>
        {step.hint && <div class="workflow-hint">{step.hint}</div>}
      </div>
    </div>
  ))}
</div>
